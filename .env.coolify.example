# ============================================================
#  Midday — Coolify Environment Variables
#  Copy this file, fill in the values, and paste into
#  Coolify → your project → Environment Variables tab
# ============================================================

# ── DOMAINS (required — no https://) ──────────────────────
DASHBOARD_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com

# ── SELF-HOSTED SETTINGS ──────────────────────────────────
# Set to false (or omit) to allow all new sign-ups.
# Set to true only if you want to block new registrations
# (e.g. midday.ai production uses true with a hardcoded cutoff date).
NEW_USER_GATE_ENABLED=false

# ── SUPABASE ───────────────────────────────────────────────
# Go to https://supabase.com → New project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SECRET_KEY=eyJ...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_PROJECT_ID=xxxxxxxxxxxx

# ── DATABASE (Supabase Pooler) ─────────────────────────────
# Settings → Database → Connection string → Transaction mode (port 6543)
DATABASE_PRIMARY_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Session mode (port 5432) — for migrations
DATABASE_SESSION_POOLER=postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── NEXT.JS ENCRYPTION ────────────────────────────────────
# Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ── RESEND (email) ────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=

# ── OPENAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── GOOGLE AI ─────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
GOOGLE_MAPS_API_KEY=AIza...

# ── CLOUDFLARE R2 STORAGE ─────────────────────────────────
# https://dash.cloudflare.com → R2 → Create bucket
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=midday-storage

# ── SECRETS (generate each with: openssl rand -hex 32) ────
INVOICE_JWT_SECRET=
FILE_KEY_SECRET=
WEBHOOK_SECRET_KEY=
MIDDAY_CACHE_API_SECRET=
MIDDAY_ENCRYPTION_KEY=
INTERNAL_API_KEY=

# ── STRIPE ────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_WEBHOOK_SECRET=

# ── POLAR (billing alternative) ───────────────────────────
POLAR_ACCESS_TOKEN=
POLAR_ENVIRONMENT=production
POLAR_WEBHOOK_SECRET=

# ── BANKING: PLAID ────────────────────────────────────────
# https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=production

# ── BANKING: GOCARDLESS ───────────────────────────────────
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# ── BANKING: TELLER ───────────────────────────────────────
TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=production
# Base64-encoded cert + key: base64 -i certificate.pem
TELLER_CERT_BASE64=
TELLER_KEY_BASE64=
TELLER_SIGNING_SECRET=

# ── AZURE DOCUMENT INTELLIGENCE ───────────────────────────
# https://portal.azure.com → Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ── LOGO.DEV ──────────────────────────────────────────────
LOGO_DEV_TOKEN=

# ── TRIGGER.DEV (background jobs) ────────────────────────
# https://cloud.trigger.dev → Project → API keys
TRIGGER_SECRET_KEY=

# ── PLAIN (customer support) ──────────────────────────────
PLAIN_API_KEY=

# ── OPENPANEL (analytics — optional) ─────────────────────
OPENPANEL_CLIENT_ID=
OPENPANEL_SECRET_KEY=

# ── SENTRY (error tracking — optional) ───────────────────
SENTRY_DSN=

# ── SLACK INTEGRATION (optional) ─────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_STATE_SECRET=
SLACK_ENCRYPTION_KEY=

# ── TELEGRAM BOT (optional) ───────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── WHATSAPP (optional) ───────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ── SENDBLUE / iMessage (optional) ───────────────────────
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=

# ── GMAIL OAUTH (optional) ────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── OUTLOOK OAUTH (optional) ──────────────────────────────
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# ── XERO (optional) ───────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# ── QUICKBOOKS (optional) ─────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=production

# ── FORTNOX (optional) ────────────────────────────────────
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=

# ── MISTRAL AI (optional) ─────────────────────────────────
MISTRAL_API_KEY=

# ── EXA AI SEARCH (optional) ──────────────────────────────
EXA_API_KEY=

# ── INSIGHTS EMAIL DIGEST (optional) ─────────────────────
INSIGHTS_ENABLED=false
